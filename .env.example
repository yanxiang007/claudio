# LLM provider — set to "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# When LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# When LLM_PROVIDER=openai (any OpenAI-compatible endpoint: OpenAI, DeepSeek, Qwen, Kimi, Ollama, vLLM, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
# Optional: enable OpenAI Responses API web search for fresher music recommendations.
OPENAI_WEB_SEARCH=false

# NetEase Cloud Music Open Platform
# Personal developers should use the official CLI backend.
NETEASE_BACKEND=unofficial
# Optional browser cookie for logged-in requests. Leave blank for public search/song URLs.
NETEASE_COOKIE=
# Optional: force favorites to use a specific playlist id. Blank = auto-detect liked songs playlist.
NETEASE_FAVORITE_PLAYLIST_ID=
NETEASE_CLI_COMMAND=node
NETEASE_CLI_ARGS=./node_modules/@music163/ncm-cli/dist/index.js

# OpenAPI backend fallback. Apply at https://developer.music.163.com — required: AppID, AppSecret, RSA private key (PKCS#8 PEM)
NETEASE_APP_ID=
NETEASE_APP_SECRET=
NETEASE_PRIVATE_KEY_PATH=./netease-private-key.pem
# Web OAuth login. The redirect URL must match the callback domain configured in the NetEase console.
NETEASE_REDIRECT_URL=http://localhost:3000/auth/netease/callback
NETEASE_CLIENT_TYPE=web
# Device identity — first run will bind anon token to this deviceId, keep it stable
NETEASE_DEVICE_ID=claudio-default-device
# These default values are for non-IoT desktop usage; if NetEase rejects them
# you may need to coordinate with their team for assigned channel/deviceType/os/brand values.
NETEASE_CHANNEL=netease
NETEASE_DEVICE_TYPE=andrcar
NETEASE_OS=andrcar
NETEASE_OS_VER=14
NETEASE_APP_VER=6.0.0
NETEASE_BRAND=netease
NETEASE_MODEL=claudio
NETEASE_CLIENT_IP=127.0.0.1
NETEASE_NET_STATUS=wifi

FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=
# Fish Audio TTS engine: s2-pro (default, higher quality) or s1
FISH_AUDIO_MODEL=s2-pro
OPENWEATHER_API_KEY=
CITY=Hangzhou
PORT=3000
