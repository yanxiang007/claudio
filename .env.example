# LLM provider — set to "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# When LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# When LLM_PROVIDER=openai (any OpenAI-compatible endpoint: OpenAI, DeepSeek, Qwen, Kimi, Ollama, vLLM, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

NETEASE_CLIENT_ID=
NETEASE_CLIENT_SECRET=
NETEASE_REFRESH_TOKEN=
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=
# Fish Audio TTS engine: s2-pro (default, higher quality) or s1
FISH_AUDIO_MODEL=s2-pro
OPENWEATHER_API_KEY=
CITY=Hangzhou
PORT=3000
